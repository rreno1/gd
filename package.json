{
  "name": "gd-learning-portal",
  "version": "1.0.0",
  "private": true,
  "description": "Static Firebase-backed Graphic Design learning portal",
  "type": "module",
  "scripts": {
    "build": "node tools/validate-static.mjs",
    "serve": "node tools/serve.mjs",
    "test": "node tests/all.unit.test.mjs",
    "test:rules": "firebase emulators:exec --only firestore \"node tests/firestore.rules.test.mjs\"",
    "check": "node tools/validate-static.mjs && node tests/all.unit.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase-admin": "^10.3.0",
    "firebase-tools": "^14.23.0"
  }
}
